# Copiez uniquement les valeurs utiles depuis Vercel ou votre .env.local.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Requis pour les agents éditoriaux.
OPENROUTER_API_KEY=
OPENROUTER_CONTENT_MODEL=openai/gpt-4.1-mini
OPENROUTER_QUIZ_MODEL=

# Mode démo : force toutes les générations texte sur un petit Qwen gratuit.
# La recherche web est coupée par défaut car elle coûte environ 0,005 $ par requête.
AI_DEMO_MODE=false
OPENROUTER_DEMO_MODEL=qwen/qwen3-4b:free
OPENROUTER_DEMO_WEB_SEARCH=false

# Réception de métriques normalisées envoyées par n8n, GA4, GSC ou AgenceFlow.
ANALYTICS_INGEST_SECRET=
SUPABASE_SERVICE_ROLE_KEY=

# Nano Banana 2 Lite via l'API Gemini (phase d'images locale à connecter).
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-3.1-flash-lite-image

# Ancien générateur OpenRouter encore utilisé par la veille YouTube.
OPENROUTER_IMAGE_MODEL=bytedance-seed/seedream-4.5
